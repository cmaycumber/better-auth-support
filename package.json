{
  "name": "better-auth-support",
  "version": "0.0.1",
  "description": "Self-hosted, embeddable support chat + agent inbox that plugs directly into a Better Auth app. Identity, users and agent roles come from Better Auth itself; ships an AI-first-responder hook and a headless React widget.",
  "author": "Automatons, LLC",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cmaycumber/better-auth-support.git"
  },
  "homepage": "https://github.com/cmaycumber/better-auth-support#readme",
  "bugs": "https://github.com/cmaycumber/better-auth-support/issues",
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "better-auth",
    "better-auth-plugin",
    "support",
    "chat",
    "live-chat",
    "customer-support",
    "helpdesk",
    "inbox",
    "react"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "prepare": "tsup"
  },
  "peerDependencies": {
    "better-auth": ">=1.2.0",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "better-auth": "^1.6.20",
    "react": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
